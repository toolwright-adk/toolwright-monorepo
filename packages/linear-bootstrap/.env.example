# LLM API key (required for generate-plan, generate-and-bootstrap)
# Any OpenAI-compatible API provider works (OpenRouter, Together, Groq, Ollama, etc.)
LLM_API_KEY=

# LLM API base URL (required)
# Examples:
#   https://openrouter.ai/api/v1
#   https://api.together.xyz/v1
#   https://api.groq.com/openai/v1
#   http://localhost:11434/v1  (Ollama)
LLM_BASE_URL=

# LLM model ID (required)
# Must match your provider's model naming. Examples:
#   anthropic/claude-sonnet-4  (OpenRouter)
#   meta-llama/Llama-3-70b-chat-hf  (Together)
#   llama3-70b-8192  (Groq)
LLM_MODEL=

# Linear API key (required for bootstrap-project, add-epic, introspect-workspace, list-teams)
LINEAR_API_KEY=
