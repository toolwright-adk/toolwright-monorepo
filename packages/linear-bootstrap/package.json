{
  "name": "@toolwright-adk/linear-bootstrap",
  "version": "0.1.0",
  "description": "MCP server for bootstrapping Linear projects from natural language descriptions",
  "license": "MIT",
  "type": "module",
  "author": "Toolwright Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/toolwright-adk/toolwright-monorepo.git",
    "directory": "packages/linear-bootstrap"
  },
  "homepage": "https://github.com/toolwright-adk/toolwright-monorepo/tree/main/packages/linear-bootstrap",
  "bugs": {
    "url": "https://github.com/toolwright-adk/toolwright-monorepo/issues"
  },
  "keywords": [
    "mcp",
    "linear",
    "project-management",
    "bootstrapping",
    "model-context-protocol"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "bin": {
    "linear-bootstrap": "dist/server.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "format:check": "prettier --check src/"
  },
  "dependencies": {
    "@linear/sdk": "^37.0.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@toolwright-adk/shared": "workspace:^",
    "openai": "^4.104.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@vitest/coverage-v8": "^2.1.9",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
