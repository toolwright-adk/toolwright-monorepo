{
  "name": "@toolwright-adk/shared",
  "version": "0.1.0",
  "description": "Shared utilities for Toolwright MCP servers",
  "license": "MIT",
  "type": "module",
  "author": "Toolwright Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/toolwright-adk/toolwright-monorepo.git",
    "directory": "packages/shared"
  },
  "homepage": "https://github.com/toolwright-adk/toolwright-monorepo/tree/main/packages/shared",
  "bugs": {
    "url": "https://github.com/toolwright-adk/toolwright-monorepo/issues"
  },
  "keywords": [
    "mcp",
    "toolwright",
    "utilities",
    "model-context-protocol"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./testing": {
      "import": "./dist/testing.js",
      "types": "./dist/testing.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "format:check": "prettier --check src/",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "pino": "^10.3.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@vitest/coverage-v8": "^2.1.9",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
